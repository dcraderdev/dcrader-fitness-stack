---
import '../styles/global.css';

export interface Props {
  title: string;
  description: string;
  active?: 'home' | 'programs' | 'workout' | 'exercises' | 'about';
  image?: string;
}

const { title, description, active, image = '/og-image.png' } = Astro.props;
const canonicalURL = new URL(Astro.url.pathname, Astro.site).toString();
const ogImage = new URL(image, Astro.site).toString();

const nav = [
  { href: '/', label: 'Home', key: 'home' },
  { href: '/programs', label: 'Programs', key: 'programs' },
  { href: '/workout', label: 'Workout', key: 'workout' },
  { href: '/exercises', label: 'Exercises', key: 'exercises' },
  { href: '/about', label: 'About', key: 'about' },
];
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#0a0a0a" />
    <title>{title}</title>
    <link rel="canonical" href={canonicalURL} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:site_name" content="Stack" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="preload"
      as="style"
      href="https://fonts.googleapis.com/css2?family=Oswald:wght@500;600;700&family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@500;600&display=swap"
    />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Oswald:wght@500;600;700&family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@500;600&display=swap"
    />

    <slot name="head" />
    <script src="/template-topheader.js" defer></script>
    <style>
      /* Offset for portfolio bar (#dcrader-th, 34px fixed top:0) injected by template-topheader.js */
      body { padding-top: 34px; }
    </style>
  </head>
  <body class="min-h-screen flex flex-col bg-stack-bone text-stack-ink">
    <a
      href="#main"
      class="sr-only focus:not-sr-only focus:fixed focus:top-4 focus:left-4 focus:z-50 focus:bg-stack-ink focus:text-white focus:px-4 focus:py-2 focus:font-bold"
    >
      Skip to main content
    </a>

    <header class="block-border-b bg-stack-bone">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 flex items-center justify-between h-14">
        <a href="/" class="flex items-center gap-2 group" aria-label="Stack — workout tracker home">
          <span class="display text-2xl tracking-tight">
            STACK<span class="text-stack-red">.</span>
          </span>
          <span class="hidden sm:inline tag text-stack-concrete">Workout Log</span>
        </a>
        <nav aria-label="Primary">
          <ul class="flex items-center gap-1 sm:gap-2">
            {nav.map((n) => (
              <li>
                <a
                  href={n.href}
                  class={`display text-sm sm:text-base px-2 sm:px-3 py-1 ${active === n.key ? 'bg-stack-ink text-stack-bone' : 'hover:bg-stack-rebar'}`}
                  aria-current={active === n.key ? 'page' : undefined}
                >
                  {n.label}
                </a>
              </li>
            ))}
          </ul>
        </nav>
      </div>
    </header>

    <main id="main" class="flex-1">
      <slot />
    </main>

    <footer class="block-border-t mt-16 bg-stack-graphite text-stack-bone">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10 grid gap-8 sm:grid-cols-3">
        <div>
          <p class="display text-3xl">STACK<span class="text-stack-red">.</span></p>
          <p class="mt-2 text-sm text-stack-rebar-soft max-w-xs">
            A minimal workout tracker for people who lift heavy things and write them down.
          </p>
        </div>
        <div>
          <p class="tag text-stack-rebar-soft">Site</p>
          <ul class="mt-3 space-y-1.5 text-sm">
            <li><a class="hover:text-stack-red-bright" href="/">Home</a></li>
            <li><a class="hover:text-stack-red-bright" href="/programs">Programs</a></li>
            <li><a class="hover:text-stack-red-bright" href="/workout">Sample workout</a></li>
            <li><a class="hover:text-stack-red-bright" href="/about">About</a></li>
          </ul>
        </div>
        <div>
          <p class="tag text-stack-rebar-soft">Contact</p>
          <ul class="mt-3 space-y-1.5 text-sm">
            <li>
              <a class="hover:text-stack-red-bright" href="mailto:hello@stack.dcrader.dev">
                hello@stack.dcrader.dev
              </a>
            </li>
            <li>
              <a class="hover:text-stack-red-bright" href="/accessibility">
                Accessibility
              </a>
            </li>
            <li class="text-stack-rebar-dim text-xs pt-2">
              &copy; {new Date().getFullYear()} Stack. Built by
              {' '}<a
                href="https://dcrader.dev"
                class="underline hover:text-stack-red-bright"
                rel="noopener"
              >Donovan Crader &middot; dcrader.dev</a>.
            </li>
          </ul>
        </div>
      </div>
    </footer>

    <script>
      if (import.meta.env.DEV) {
        // Scroll through the document once so axe-core's pixel-based bg detection
        // samples the correct backgrounds for offscreen sections before auditing.
        const audit = async () => {
          const { default: axe } = await import('axe-core');
          const startY = window.scrollY;
          const docH = document.documentElement.scrollHeight;
          const step = Math.max(200, window.innerHeight - 100);
          for (let y = 0; y < docH; y += step) {
            window.scrollTo(0, y);
            await new Promise((r) => setTimeout(r, 30));
          }
          window.scrollTo(0, startY);
          await new Promise((r) => setTimeout(r, 100));
          const results = await axe.run();
          if (results.violations.length) {
            console.group('%c axe violations', 'color:red;font-weight:bold');
            results.violations.forEach((v) => console.error(v.id, v.description, v.nodes));
            console.groupEnd();
          } else {
            console.log('%c axe: 0 violations', 'color:green;font-weight:bold');
          }
        };
        if (document.readyState === 'complete') audit();
        else window.addEventListener('load', () => setTimeout(audit, 200));
      }
    </script>
  </body>
</html>
