---
import StackLayout from '../layouts/StackLayout.astro';
import { week, prs, sampleWorkout } from '../data/content.ts';

const fmtDate = (iso: string) =>
  new Date(iso + 'T00:00:00').toLocaleDateString('en-US', { month: 'short', day: 'numeric' });

const totalVolume = sampleWorkout.exercises.reduce((sum, ex) => {
  return sum + ex.sets.reduce((s, set) => {
    const load = typeof set.load === 'number' ? set.load : 0;
    const reps = typeof set.reps === 'number' ? set.reps : 0;
    return s + load * reps;
  }, 0);
}, 0);
---
<StackLayout
  title="Stack — Workout log for people who lift heavy things"
  description="A minimal-brutalist workout tracker. Log sets, reps, and load. Watch the numbers go up."
  active="home"
>
  {/* HERO */}
  <section class="block-border-b bg-stack-bone">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-14 sm:py-20 grid lg:grid-cols-12 gap-8 items-end">
      <div class="lg:col-span-7">
        <p class="tag text-stack-red">EST. 2026 · BARBELL FIRST</p>
        <h1 class="display text-[12vw] sm:text-[10vw] lg:text-[8.5rem] xl:text-[10rem] mt-3 leading-[0.85]">
          LOG IT.<br/>
          LIFT IT.<br/>
          <span class="text-stack-red">STACK IT.</span>
        </h1>
        <p class="mt-6 max-w-xl text-base sm:text-lg text-stack-graphite">
          A workout log that doesn't get in the way. Sets, reps, load.
          No streaks, no leaderboards, no &ldquo;influencer programs.&rdquo;
          Just the numbers and the bar.
        </p>
        <div class="mt-8 flex flex-wrap gap-3">
          <a
            href="/workout"
            class="display text-lg bg-stack-ink text-stack-bone px-5 py-3 hover:bg-stack-red transition-colors block-border"
          >
            See a workout &rarr;
          </a>
          <a
            href="/programs"
            class="display text-lg bg-transparent text-stack-ink px-5 py-3 hover:bg-stack-ink hover:text-stack-bone transition-colors block-border"
          >
            Browse programs
          </a>
        </div>
      </div>

      {/* Big numeral panel */}
      <div class="lg:col-span-5">
        <div class="bg-stack-ink text-stack-bone p-6 block-border">
          <p class="tag text-stack-red-bright">CURRENT TOP SET</p>
          <p class="display text-sm mt-3 text-stack-rebar">Back Squat &mdash; 5x1 wave, Week 4</p>
          <p class="numeral text-[8rem] sm:text-[10rem] leading-none mt-2">315</p>
          <p class="display text-2xl text-stack-bone -mt-2">lbs &times; 1</p>
          <div class="mt-6 pt-4 border-t border-stack-concrete/40 grid grid-cols-3 gap-2 text-center">
            <div>
              <p class="numeral text-3xl">{sampleWorkout.durationMin}</p>
              <p class="tag text-stack-rebar-soft mt-1">min</p>
            </div>
            <div>
              <p class="numeral text-3xl">{sampleWorkout.rpe}</p>
              <p class="tag text-stack-rebar-soft mt-1">RPE</p>
            </div>
            <div>
              <p class="numeral text-3xl">{(totalVolume / 1000).toFixed(1)}k</p>
              <p class="tag text-stack-rebar-soft mt-1">lb vol</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  {/* MARQUEE BAR */}
  <section aria-hidden="true" class="bg-stack-red text-stack-bone overflow-hidden">
    <div class="flex whitespace-nowrap py-3 gap-8 display text-lg">
      {Array.from({ length: 2 }).map(() => (
        <span class="flex gap-8 px-4">
          <span>SQUAT</span><span>&middot;</span>
          <span>BENCH</span><span>&middot;</span>
          <span>DEADLIFT</span><span>&middot;</span>
          <span>PRESS</span><span>&middot;</span>
          <span>ROW</span><span>&middot;</span>
          <span>CHIN</span><span>&middot;</span>
          <span>CARRY</span><span>&middot;</span>
          <span>REPEAT</span><span>&middot;</span>
        </span>
      ))}
    </div>
  </section>

  {/* WEEKLY PLAN */}
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <header class="flex items-end justify-between flex-wrap gap-3 mb-8">
      <div>
        <p class="tag text-stack-red">/01 — THIS WEEK</p>
        <h2 class="display text-5xl sm:text-6xl mt-2">The plan.</h2>
      </div>
      <a href="/programs" class="display text-sm hover:text-stack-red">View full program &rarr;</a>
    </header>

    <ol class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-7 gap-0 block-border">
      {week.map((d, i) => (
        <li class={`p-4 ${i !== week.length - 1 ? 'border-r-0 sm:border-r-2 border-stack-ink lg:border-r-2 border-b-2 sm:border-b-2 lg:border-b-0' : ''} ${d.type === 'Rest' ? 'bg-stack-rebar/40' : d.type === 'Lift' ? 'bg-stack-paper' : 'bg-stack-bone'}`}>
          <p class="flex items-center justify-between">
            <span class="display text-2xl">{d.day}</span>
            <span class={`tag ${d.type === 'Lift' ? 'text-stack-red' : 'text-stack-concrete'}`}>{d.type}</span>
          </p>
          <p class="mt-3 display text-base">{d.title}</p>
          {d.bigLift && (
            <p class="mt-2 numeral text-lg text-stack-graphite">{d.bigLift}</p>
          )}
        </li>
      ))}
    </ol>
  </section>

  {/* PR FEED */}
  <section class="bg-stack-graphite text-stack-bone">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
      <header class="flex items-end justify-between flex-wrap gap-3 mb-8">
        <div>
          <p class="tag text-stack-red-bright">/02 — RECENT PRs</p>
          <h2 class="display text-5xl sm:text-6xl mt-2 text-stack-bone">Numbers up.</h2>
        </div>
        <p class="text-sm text-stack-rebar-soft max-w-sm">
          Personal records logged this training cycle. Estimated 1RM uses the Epley formula.
        </p>
      </header>

      <ul class="grid gap-3 sm:grid-cols-2 lg:grid-cols-4">
        {prs.map((pr) => (
          <li class="bg-stack-ink p-5 border-2 border-stack-concrete/40 hover:border-stack-red transition-colors">
            <div class="flex items-baseline justify-between">
              <p class="display text-lg text-stack-bone">{pr.lift}</p>
              <p class="tag text-stack-rebar-soft">{fmtDate(pr.date)}</p>
            </div>
            <p class="numeral text-6xl text-stack-bone mt-3">
              {pr.weight}<span class="text-2xl text-stack-rebar-soft ml-1">lb</span>
            </p>
            <p class="mt-1 text-sm text-stack-rebar-soft">
              {pr.reps} {pr.reps === 1 ? 'rep' : 'reps'} &middot; e1RM <span class="text-stack-red-bright font-semibold">{pr.e1rm}</span>
            </p>
          </li>
        ))}
      </ul>
    </div>
  </section>

  {/* CTA strip */}
  <section class="block-border-t bg-stack-bone">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16 grid lg:grid-cols-2 gap-8 items-center">
      <div>
        <p class="tag text-stack-red">/03 — THE BAR DOESN'T CARE</p>
        <h2 class="display text-5xl sm:text-6xl mt-2">Show up. Log it. Add weight.</h2>
        <p class="mt-4 max-w-xl text-stack-graphite">
          Stack is a concept project &mdash; a workout log built like a pre-cast concrete bench.
          Heavy, square, and not pretending to be anything else.
        </p>
      </div>
      <div class="bg-stack-ink text-stack-bone p-6 block-border">
        <p class="tag text-stack-red-bright">NEXT SESSION</p>
        <p class="display text-3xl mt-3">Lower / Heavy</p>
        <p class="mt-1 text-sm text-stack-rebar">{sampleWorkout.day}</p>
        <a href="/workout" class="mt-5 inline-block display bg-stack-bone text-stack-ink px-4 py-2 hover:bg-stack-red hover:text-stack-bone">
          Open workout &rarr;
        </a>
      </div>
    </div>
  </section>
</StackLayout>
