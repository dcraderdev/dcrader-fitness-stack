---
import StackLayout from '../layouts/StackLayout.astro';
---
<StackLayout
  title="Accessibility Statement — Stack"
  description="Accessibility statement for Stack. We aim to conform to WCAG 2.1 Level AA."
>
  <section class="max-w-3xl mx-auto px-6 py-16 prose">
    <h1 class="display text-5xl sm:text-6xl">Accessibility Statement</h1>
    <p class="mt-6 text-stack-graphite">
      We are committed to ensuring digital accessibility for people with disabilities.
      We are continually improving the user experience for everyone and applying the
      relevant accessibility standards.
    </p>

    <h2 class="display text-3xl mt-10">Conformance status</h2>
    <p class="mt-2 text-stack-graphite">
      This site aims to conform to <strong>WCAG 2.1 Level AA</strong>.
    </p>

    <h2 class="display text-3xl mt-10">Feedback</h2>
    <p class="mt-2 text-stack-graphite">
      Contact us at <a class="underline hover:text-stack-red" href="mailto:dcraderdev@gmail.com">dcraderdev@gmail.com</a>.
    </p>

    <h2 class="display text-3xl mt-10">Compatibility</h2>
    <p class="mt-2 text-stack-graphite">
      Designed to be compatible with recent browsers and screen readers.
    </p>

    <p class="mt-10 text-stack-concrete"><em>Last updated: 2026-05-17</em></p>
  </section>
</StackLayout>
